      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "ecommerce-test-54853",
          "configurations": {
            "android": "1:368682073122:android:c4c1c3337f2f4c7bc31e7b",
            "ios": "1:368682073122:ios:ef8711a92433b46ac31e7b",
            "macos": "1:368682073122:ios:ef8711a92433b46ac31e7b",
